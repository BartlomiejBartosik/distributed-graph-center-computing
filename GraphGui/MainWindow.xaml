<Window x:Class="GraphGui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rozproszone obliczanie centrum grafu"
        Height="720"
        Width="1150"
        Background="#1E1E1E"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="#252526"
                CornerRadius="12"
                Padding="18"
                Margin="0,0,20,0">

            <StackPanel>

                <TextBlock Text="Panel sterowania"
                           Foreground="White"
                           FontSize="24"
                           FontWeight="Bold"
                           Margin="0,0,0,20"/>

                <TextBlock Text="Serwer gRPC: localhost:5000"
                           Foreground="#BDBDBD"
                           FontSize="14"
                           Margin="0,0,0,20"/>

                <Button Content="Wczytaj graf z CSV"
                        Height="42"
                        Margin="0,0,0,10"
                        Click="LoadCsv_Click"/>

                <Button Content="Wygeneruj graf"
                        Height="42"
                        Margin="0,0,0,10"
                        Click="GenerateGraph_Click"/>

                <Button Content="Zapisz graf do CSV"
                        Height="42"
                        Margin="0,0,0,10"
                        Click="SaveCsv_Click"/>

                <TextBlock Text="Liczba wierzchołków:"
                           Foreground="White"
                           Margin="0,15,0,5"/>

                <TextBox x:Name="VertexCountTextBox"
                         Text="100"
                         Height="32"
                         Margin="0,0,0,10"/>

                <TextBlock Text="Dodatkowe krawędzie:"
                           Foreground="White"
                           Margin="0,0,0,5"/>

                <TextBox x:Name="ExtraEdgesTextBox"
                         Text="150"
                         Height="32"
                         Margin="0,0,0,10"/>

                <TextBlock Text="Rozmiar chunku:"
                           Foreground="White"
                           Margin="0,0,0,5"/>

                <TextBox x:Name="ChunkSizeTextBox"
                         Text="20"
                         Height="32"
                         Margin="0,0,0,15"/>

                <Button Content="Policz centrum grafu"
                        Height="48"
                        FontWeight="Bold"
                        Click="CalculateCenter_Click"/>

                <Separator Margin="0,20,0,20"/>

                <TextBlock Text="Aktywni workerzy"
                           Foreground="White"
                           FontSize="17"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>

                <ListBox x:Name="WorkersListBox"
                         Height="120"
                         Margin="0,0,0,10"/>

                <Button Content="Odśwież workerów"
                        Height="36"
                        Click="RefreshWorkers_Click"/>

                <Separator Margin="0,20,0,20"/>

                <TextBlock x:Name="StatusTextBlock"
                           Text="Status: serwer uruchomiony"
                           Foreground="#BDBDBD"
                           TextWrapping="Wrap"
                           FontSize="14"
                           Margin="0,0,0,10"/>

                <TextBlock x:Name="ResultTextBlock"
                           Text="Wynik: brak"
                           Foreground="White"
                           TextWrapping="Wrap"
                           FontSize="15"/>

            </StackPanel>
        </Border>

        <Border Grid.Column="1"
                Background="#2D2D30"
                CornerRadius="12"
                Padding="10">

            <Grid>
                <TextBlock Text="Podgląd grafu"
                           Foreground="White"
                           FontSize="18"
                           FontWeight="Bold"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Top"
                           Margin="10"/>

                <Canvas x:Name="GraphCanvas"
                        Background="#252526"
                        Margin="0,45,0,0"/>
            </Grid>

        </Border>
    </Grid>
</Window>